{
  "name": "attendancy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "pnpm db:format pnpm lint && pnpm typecheck && pnpm format:check",
    "db:generate": "dotenv -e .env.development -- prisma generate",
    "db:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "db:push": "dotenv -e .env.development -- prisma db push",
    "db:studio": "dotenv -e .env.development -- prisma studio",
    "db:reset": "dotenv -e .env.development -- prisma migrate reset",
    "db:seed": "dotenv -e .env.development -- tsx prisma/seed.ts",
    "db:format": "prisma format",
    "docker:up": "docker compose -f docker/dev/compose.yml --env-file .env.development up -d",
    "docker:down": "docker compose -f docker/dev/compose.yml --env-file .env.development down",
    "docker:logs": "docker compose -f docker/dev/compose.yml --env-file .env.development logs -f",
    "docker:restart": "pnpm run docker:down && pnpm run docker:up",
    "prepare": "husky",
    "worker:email": "dotenv -e .env.development -- tsx src/features/mail/mail.worker.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ],
    "*.prisma": [
      "prisma format"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.79.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "ms": "^2.1.3",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/ms": "^2.1.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "typescript-eslint": "^8.62.0"
  }
}
