generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Provider {
  LOCAL
  GOOGLE
}

model User {
  id              String     @id @default(cuid())
  firstName       String
  lastName        String
  email           String     @unique
  emailVerifiedAt DateTime?
  passwordHash    String?
  avatar          String?
  provider        Provider   @default(LOCAL)
  providerId      String?
  status          UserStatus @default(INACTIVE)

  sessions Session[]
  roles    Role[]    @relation("UserRoles")
  otps     Otp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  // Kept for a short grace window after rotation so a request racing on the
  // just-superseded refresh token isn't treated as reuse/theft and logged out.
  previousRefreshTokenHash      String?
  previousRefreshTokenExpiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  resource    String
  action      String
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([resource, action])
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR
}

model Otp {
  id            String    @id @default(cuid())
  userId        String
  type          OtpType
  codeHash      String
  expiresAt     DateTime
  usedAt        DateTime?
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, usedAt, expiresAt])
  @@index([expiresAt])
}

model Department {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Position {
  id          String  @id @default(cuid())
  title       String  @unique
  description String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
