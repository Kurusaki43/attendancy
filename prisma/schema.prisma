generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum Provider {
  LOCAL
  GOOGLE
}

enum Gender {
  MALE
  FEMALE
}

enum EmploymentStatus {
  ACTIVE
  TERMINATED
}

model User {
  id              String     @id @default(cuid())
  firstName       String
  lastName        String
  email           String     @unique
  emailVerifiedAt DateTime?  @db.Timestamptz(3)
  passwordHash    String?
  avatar          String?
  provider        Provider   @default(LOCAL)
  providerId      String?
  status          UserStatus @default(INACTIVE)
  locale          String     @default("en")
  timezone        String     @default("America/New_York")

  sessions Session[]
  roles    Role[]    @relation("UserRoles")
  otps     Otp[]
  employee Employee?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime  @db.Timestamptz(3)
  revokedAt        DateTime? @db.Timestamptz(3)

  previousRefreshTokenHash      String?
  previousRefreshTokenExpiresAt DateTime? @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)
}

model Permission {
  id          String   @id @default(cuid())
  resource    String
  action      String
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@unique([resource, action])
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR
  EMPLOYEE_INVITE
}

model Otp {
  id            String    @id @default(cuid())
  userId        String
  type          OtpType
  codeHash      String
  expiresAt     DateTime  @db.Timestamptz(3)
  usedAt        DateTime? @db.Timestamptz(3)
  invalidatedAt DateTime? @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, usedAt, expiresAt])
  @@index([expiresAt])
}

model Department {
  id          String  @id @default(cuid())
  name        String  @unique
  code        String  @unique
  description String?
  icon        String?
  color       String?

  parentId String?
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DepartmentHierarchy")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  employees Employee[]

  @@index([parentId])
}

model Position {
  id          String  @id @default(cuid())
  title       String  @unique
  code        String  @unique
  description String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  employees Employee[]
}

model Employee {
  id           String   @id @default(cuid())
  employeeCode String   @unique
  phone        String?
  hireDate     DateTime @db.Timestamptz(3)

  gender    Gender?
  birthDate DateTime? @db.Timestamptz(3)
  address   String?

  userId       String  @unique
  managerId    String?
  departmentId String?
  positionId   String?

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  manager      Employee?   @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates Employee[]  @relation("EmployeeManager")
  department   Department? @relation(fields: [departmentId], references: [id])
  position     Position?   @relation(fields: [positionId], references: [id])

  employmentStatus EmploymentStatus @default(ACTIVE)
  createdAt        DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(3)

  attendances Attendance[]
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  ON_LEAVE
  HOLIDAY
}

enum AttendanceCompletionStatus {
  COMPLETE
  INCOMPLETE
}

enum AttendanceEventType {
  CLOCK_IN
  CLOCK_OUT
}

enum AttendanceMethod {
  QR
  FACE
  FINGERPRINT
  MANUAL
}

model Attendance {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date             DateTime                    @db.Timestamptz(3)
  firstClockIn     DateTime?                   @db.Timestamptz(3)
  lastClockOut     DateTime?                   @db.Timestamptz(3)
  workedMinutes    Int                         @default(0)
  status           AttendanceStatus
  // Only meaningful when status == PRESENT; ABSENT/ON_LEAVE/HOLIDAY have no events so this is null
  completionStatus AttendanceCompletionStatus?
  events           AttendanceEvent[]

  // True if at least one event was manually added or edited
  hasManualChanges Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([employeeId, date])
}

model AttendanceEvent {
  id String @id @default(cuid())

  attendanceId String
  attendance   Attendance          @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  type         AttendanceEventType
  occurredAt   DateTime            @db.Timestamptz(3)
  method       AttendanceMethod
  // Only required when method == MANUAL
  reason       String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
}
