generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum Provider {
  LOCAL
  GOOGLE
}

enum Gender {
  MALE
  FEMALE
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

model User {
  id              String     @id @default(cuid())
  firstName       String
  lastName        String
  email           String     @unique
  emailVerifiedAt DateTime?
  passwordHash    String?
  avatar          String?
  provider        Provider   @default(LOCAL)
  providerId      String?
  status          UserStatus @default(INACTIVE)

  sessions Session[]
  roles    Role[]    @relation("UserRoles")
  otps     Otp[]
  employee Employee?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  previousRefreshTokenHash      String?
  previousRefreshTokenExpiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]       @relation("UserRoles")
  permissions Permission[] @relation("RolePermissions")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  resource    String
  action      String
  description String?
  roles       Role[]   @relation("RolePermissions")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([resource, action])
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR
  EMPLOYEE_INVITE
}

model Otp {
  id            String    @id @default(cuid())
  userId        String
  type          OtpType
  codeHash      String
  expiresAt     DateTime
  usedAt        DateTime?
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, usedAt, expiresAt])
  @@index([expiresAt])
}

model Department {
  id          String  @id @default(cuid())
  name        String  @unique
  code        String  @unique
  description String?
  icon        String?
  color       String?

  parentId String?
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DepartmentHierarchy")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@index([parentId])
}

model Position {
  id          String  @id @default(cuid())
  title       String  @unique
  code        String  @unique
  description String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
}

model Employee {
  id           String   @id @default(cuid())
  employeeCode String   @unique
  phone        String?
  hireDate     DateTime

  gender    Gender?
  birthDate DateTime?
  address   String?

  userId       String  @unique
  managerId    String?
  departmentId String?
  positionId   String?

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  manager      Employee?   @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates Employee[]  @relation("EmployeeManager")
  department   Department? @relation(fields: [departmentId], references: [id])
  position     Position?   @relation(fields: [positionId], references: [id])

  employmentStatus EmploymentStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  attendances Attendance[]
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  ON_LEAVE
  HOLIDAY
}

enum AttendanceEventType {
  CLOCK_IN
  CLOCK_OUT
}

enum AttendanceMethod {
  QR
  FACE
  FINGERPRINT
  MANUAL
}

model Attendance {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date          DateTime
  firstClockIn  DateTime?
  lastClockOut  DateTime?
  workedMinutes Int               @default(0)
  status        AttendanceStatus
  events        AttendanceEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
}

model AttendanceEvent {
  id String @id @default(cuid())

  attendanceId String
  attendance   Attendance          @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  type         AttendanceEventType
  occurredAt   DateTime
  method       AttendanceMethod

  createdAt DateTime @default(now())
}
